# Supabase (Required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Container names (match your Docker setup)
HBBS_CONTAINER_NAME=hbbs
HBBR_CONTAINER_NAME=hbbr

# RustDesk data path (where db_v2.sqlite3 lives)
SQLITE_DB_PATH=/data/db_v2.sqlite3

# Intervals
PEER_SYNC_INTERVAL_MS=60000
HEARTBEAT_TIMEOUT_MS=300000
HEARTBEAT_GRACE_MS=600000

# Logging
LOG_LEVEL=info

# Note: UDP Capture service is a separate container (rustpanel-udp-capture)
# It captures HBBS update_pk packets directly from network interface
# See root .env.example for UDP capture configuration
