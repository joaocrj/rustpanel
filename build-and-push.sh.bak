log_warn()    { echo -e "${YELLOW}[WARN]${NC}  $*"; }
log_error()   { echo -e "${RED}[ERROR]${NC} $*"; }
log_section() { echo -e "\n${GREEN}============================================================${NC}"; echo -e "${GREEN} $*${NC}"; echo -e "${GREEN}============================================================${NC}\n"; }

# ---- Parse args ----
BUILD_FRONTEND=false
BUILD_AGENT=false
BUILD_UDP_CAPTURE=false

for arg in "$@"; do
    case "$arg" in
