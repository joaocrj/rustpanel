# =============================================================
# RustPanel - Environment Variables (Root)
# =============================================================
# Copy this file to .env and fill in your values.
# The root .env is used for deploy scripts (build-and-push.ps1,
# deploy-vps.sh) and Docker Swarm stack deployment.
#
# IMPORTANT: Never commit actual credentials to version control.
# =============================================================

# Supabase Backend (used by Agent and scripts)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# RustDesk Server containers
HBBS_CONTAINER_NAME=hbbs
HBBR_CONTAINER_NAME=hbbr