# =============================================================
# RustPanel - Environment Variables (Root)
# =============================================================
# Copy this file to .env and fill in your values.
# The root .env is used for deploy scripts (build-and-push.ps1,
# deploy-vps.sh) and Docker Swarm stack deployment.
#
# IMPORTANT: Never commit actual credentials to version control.
# =============================================================

# Supabase Backend (used by Agent and scripts)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# RustDesk Server containers
HBBS_CONTAINER_NAME=hbbs
HBBR_CONTAINER_NAME=hbbr

# UDP Capture (Rust) - Captures HBBS update_pk packets
# CAPTURE_INTERFACE=any      # Network interface (e.g., eth0, docker0, any)
# CAPTURE_PORT=21116         # HBBS UDP port
# BATCH_SIZE=50              # Batch size for Supabase upserts
# BATCH_FLUSH_MS=1000        # Flush interval in milliseconds
# LOG_LEVEL=info             # Log level (trace, debug, info, warn, error)
